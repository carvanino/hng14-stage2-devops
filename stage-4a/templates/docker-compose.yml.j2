version: "3.8"

networks:
  {{ network_name }}:
    driver: {{ network_driver }}

volumes:
  app-logs:
  nginx-logs:

services:
  app:
    image: {{ service_image }}
    container_name: swiftdeploy-app
    restart: unless-stopped
    environment:
      - MODE={{ mode }}
      - APP_VERSION={{ app_version }}
      - APP_PORT={{ service_port }}
    volumes:
      - app-logs:/app/logs
    networks:
      - {{ network_name }}
    expose:
      - "{{ service_port }}"
    cap_drop:
      - ALL
    healthcheck:
      test: ["CMD", "python3", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:{{ service_port }}/healthz')"]
      interval: 10s
      timeout: 5s
      retries: 6
      start_period: 10s

  nginx:
    image: {{ nginx_image }}
    container_name: swiftdeploy-nginx
    restart: unless-stopped
    ports:
      - "{{ nginx_port }}:{{ nginx_port }}"
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
      - nginx-logs:/var/log/nginx
    networks:
      - {{ network_name }}
    depends_on:
      app:
        condition: service_healthy

  opa:
    image: openpolicyagent/opa:latest-static
    container_name: swiftdeploy-opa
    restart: unless-stopped
    # Exposed to host so CLI can query it — NOT routed through Nginx
    ports:
      - "8181:8181"
    volumes:
      - ./policies:/policies:ro
    networks:
      - {{ network_name }}
    command:
      - "run"
      - "--server"
      - "--addr=0.0.0.0:8181"
      - "--log-level=error"
      - "/policies"
